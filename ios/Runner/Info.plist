<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Awing</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>awing_ai_learning</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>NSMicrophoneUsageDescription</key>
	<string>Awing AI Learning needs microphone access for pronunciation practice and audio recording.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Awing AI Learning uses speech recognition to check your Awing pronunciation.</string>
	<!-- Local-network permission: required by network_info_plus + nsd packages.
	     Used so a teacher's device can host a classroom exam session over Wi-Fi
	     and student devices can discover and join via mDNS. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>Awing AI Learning uses your local Wi-Fi network so teachers can host classroom exam sessions and students can discover and join nearby sessions.</string>
	<!-- Photo library + camera purpose strings — required by Apple even though
	     the app does not directly use these APIs. file_picker / share_plus /
	     image_picker pull in iOS frameworks that reference PhotoKit; Apple's
	     static analyzer (rejection 90683) flags any binary that references the
	     PhotoKit symbols regardless of whether the user-facing flow uses them. -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Awing AI Learning does not use your photo library. This permission is required only because a third-party library bundled with the app references the Photos framework.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Awing AI Learning does not save anything to your photo library. This permission is required only because a third-party library bundled with the app references the Photos framework.</string>
	<key>NSCameraUsageDescription</key>
	<string>Awing AI Learning does not use your camera. This permission is required only because a third-party library bundled with the app references the Camera framework.</string>
	<!-- Bonjour service types we register/browse via mDNS. The single service
	     here is the Kahoot-style exam discovery service used by exam_service.dart.
	     iOS 14+ requires every Bonjour service type to be declared here or
	     mDNS calls return no results. -->
	<key>NSBonjourServices</key>
	<array>
		<string>_awing-exam._tcp</string>
	</array>
	<!-- Google Sign-In URL scheme — REVERSED_CLIENT_ID from
	     ios/Runner/GoogleService-Info.plist (Firebase project sanguine-frame-291822,
	     iOS app com.awing.awingAiLearning, registered Session 57b 2026-04-27).
	     Required for the Google Sign-In OAuth callback on iOS; without this URL
	     scheme, login fails silently. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>google-sign-in</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.1060398800208-d6na73hg4bpfmf0vvkcs3ms263oqt45q</string>
			</array>
		</dict>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
