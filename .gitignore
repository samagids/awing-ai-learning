# Training corpus — raw data and derived outputs are large and per-developer.
# We keep the layout docs (README.md, PROVENANCE_TEMPLATE.json) committed so
# the directory structure is documented; the actual audio/video/text files
# are not.
corpus/raw/**
!corpus/raw/README.md
!corpus/raw/**/README.md
!corpus/raw/PROVENANCE_TEMPLATE.json
!corpus/raw/.gitkeep
corpus/aligned/
corpus/manifest.jsonl
corpus/manifest_stats.json

# Contributions (approved files are temporary, applied/ is archive)
contributions/approved_contributions.json
contributions/applied/
contributions/last_version.txt
contributions/regenerate_words.json

# Clasp project dirs (contain .clasp.json with script IDs)
scripts/clasp_analytics/
scripts/clasp_contributions/

# Large files — model and video downloads
assets/model.tflite
assets/onnx_model/
*.mp4
*.wav

# Large reference files (keep PDFs, skip huge HTML exports)
awing english.htm

# Android Gradle cache
android/.gradle/

# Secrets / keys
*.jks
*.keystore
key.properties
# google-services.json is committed — it contains public project IDs, not secrets.
# It's required by GitHub Actions CI to build the APK.
# Same rationale for iOS GoogleService-Info.plist: Firebase config keys are
# bundle-ID-restricted, designed to ship inside the binary, and required by
# CI to build a signed IPA.
GoogleService-Info.plist
!ios/Runner/GoogleService-Info.plist

# CocoaPods (rebuilt by pod install)
ios/Pods/
ios/.symlinks/
ios/Podfile.lock

# Flutter generated
.flutter-plugins
.packages

