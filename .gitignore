# iOS code-signing material — NEVER commit. The .p12 + private_key.pem are
# permanent credentials that, if leaked, let anyone sign apps as "Apple
# Distribution: Guidion Sama". Apple has no recovery — only revocation +
# re-issue. The whole scripts/_ios_signing/ directory is local-only.
scripts/_ios_signing/
*.p12
*.mobileprovision
private_key.pem
*_base64.txt

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

